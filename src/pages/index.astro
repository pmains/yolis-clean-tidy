---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTAButton from '@/components/CTAButton.astro';
import company from '@/data/company.json';
import homepage from '@/data/homepage.json';
---

<BaseLayout title={company.seo.title} description={company.seo.description}>
  <div class="content-grid">
    <div class="col-left">
      <h2>{homepage.hero.title}</h2>
      <p>{homepage.hero.subtitle}</p>
      <p>{homepage.hero.description}</p>

      <CTAButton phone={company.phoneDisplay} label={homepage.hero.cta} />

      <img src="/images/theme/mop.jpeg" alt="Professional garage floor cleaning service in Mesa, AZ" loading="lazy" />

      <p>Call today, and let us prove to you that we are the best cleaners in Arizona!</p>
      <p>{homepage.serviceArea.description}</p>

      <div class="content-panel">
        <h2>{homepage.hours.title}</h2>
        <div class="text-center">
          {homepage.hours.lines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      </div>
    </div>

    <div class="col-right">
      <img src="/images/theme/sofa.jpg" alt="Freshly cleaned living room after professional house cleaning service" loading="lazy" />

      <div class="content-panel">
        <h2>Maid Schedules Available</h2>
        <ul class="check-list">
          {homepage.schedules.map((schedule) => (
            <li>{schedule}</li>
          ))}
        </ul>
      </div>

      <img src="/images/theme/clean-bathroom.jpg" alt="Sparkling clean bathroom after maid service in Phoenix" loading="lazy" />
    </div>
  </div>
</BaseLayout>
